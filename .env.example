# ─── Frontend (Vite) ───────────────────────────────────────────────────────────
# Link do checkout usado na landing page
VITE_KIWIFY_CHECKOUT_URL=https://pay.kiwify.com.br/avY1khc

# ─── Backend ───────────────────────────────────────────────────────────────────
# Porta do servidor Express (padrão: 3001)
PORT=3001

# Segredo para assinar os tokens JWT — use uma string longa e aleatória em produção!
JWT_SECRET=mude-este-valor-para-algo-secreto-em-producao

# Caminho do banco SQLite (padrão: atelier21.db na raiz do projeto)
DB_PATH=atelier21.db

# URL do frontend (usada no CORS em dev)
FRONTEND_URL=http://localhost:3000

# URL pública do login usada no email automático
APP_LOGIN_URL=https://oatelier21.com.br/login

# ─── Kiwify ────────────────────────────────────────────────────────────────────
# Token de autenticação do webhook (configure o mesmo valor no painel da Kiwify)
KIWIFY_WEBHOOK_TOKEN=seu-token-secreto-kiwify

# ─── Email automático (Resend) ─────────────────────────────────────────────────
# Compatível com a estrutura já usada em outros projetos da VPS:
# EMAIL_PROVIDER=resend
# EMAIL_FROM=Atelier 21 <acesso@oatelier21.com.br>

# Provider de email (hoje o projeto suporta Resend)
EMAIL_PROVIDER=resend

# Chave da API do Resend
RESEND_API_KEY=re_xxxxxxxxx

# Endereço remetente validado no Resend
RESEND_FROM_EMAIL=Atelier 21 <acesso@oatelier21.com.br>

# Alias compatível com outros projetos da VPS
EMAIL_FROM=Atelier 21 <acesso@oatelier21.com.br>

# ─── Admin ─────────────────────────────────────────────────────────────────────
# Senha para acessar rotas administrativas (/api/admin/*)
ADMIN_SECRET=sua-senha-admin-secreta
